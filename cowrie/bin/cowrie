#!/usr/bin/env bash
# cowrie/bin/cowrie - manage this Cowrie instance
set -e

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_BIN="$BASE_DIR/cowrie-venv/bin"
PIDFILE="$BASE_DIR/var/run/cowrie.pid"

. "$VENV_BIN/activate"

REPO_ROOT="$(cd "$BASE_DIR/.." && pwd)"
export PYTHONPATH="$REPO_ROOT:${BASE_DIR}/src:${PYTHONPATH:-}"

start() {
  echo "Starting Cowrie..."
  cd "$BASE_DIR"
  exec "$VENV_BIN/twistd" --umask=0022 \
    --rundir "$BASE_DIR" \
    --pidfile "$PIDFILE" \
    --logger cowrie.python.logfile.logger cowrie
}

stop() {
  if [ -f "$PIDFILE" ]; then
    PID="$(cat "$PIDFILE")"
    if kill "$PID" 2>/dev/null; then
      echo "Stopped Cowrie (PID $PID)"
    fi
    rm -f "$PIDFILE"
  else
    echo "No pidfile at $PIDFILE (already stopped?)"
  fi
}

restart() {
  stop
  # small sleep to ensure port is free
  sleep 1
  start
}

case "$1" in
  start|"")
    start
    ;;
  stop)
    stop
    ;;
  restart)
    restart
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac